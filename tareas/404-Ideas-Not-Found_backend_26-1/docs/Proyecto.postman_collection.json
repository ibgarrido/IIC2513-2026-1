              ],
              "variable": [
                {
                  "key": "productId",
                  "value": "9b9b0177-bf4b-4d60-bb67-6ae63aa3a3fa"
                }
              ]
            },
            "description": "ruta: /catalog/:productId\n\nRecibe como parametro productId\n\ncon esto, se obtiene la información asociada a un producto.\n\nrespuesta tipica: 200 ok\n\n``` json\n{\n    \"data\": {\n        \"id\": \"9b9b0177-bf4b-4d60-bb67-6ae63aa3a3fc\",\n        \"nombre\": \"Camiseta Manga Corta\",\n        \"descripcion\": \"Camiseta deportiva de secado rápido\",\n        \"precioBase\": 17990,\n        \"image_url\": \"https://placehold.co/400x400?text=Camiseta\",\n        \"activo\": true,\n        \"variantes\": [\n            {\n                \"id\": \"0d3da936-673f-48c3-bf46-16f65de76771\",\n                \"talla\": \"M\",\n                \"color\": \"Blanco\",\n                \"extraPrice\": 0\n            },\n            {\n                \"id\": \"727a7619-4478-4e49-be24-2db4afb187fa\",\n                \"talla\": \"L\",\n                \"color\": \"Azul Navy\",\n                \"extraPrice\": 0\n            }\n        ],\n        \"categoria\": {\n            \"nombre\": \"Ropa\",\n            \"descripcion\": \"Prendas de vestir para hombres y mujeres\"\n        }\n    }\n}\n\n ```\n\nRespuesta de producto no encontrado: 400 Not Found\n\n``` json\n{\n    \"error\": \"No se ha encontrado el producto.\"\n}\n\n ```"
          },
          "response": []
        }
      ]
